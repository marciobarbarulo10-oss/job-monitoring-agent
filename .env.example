# ============================================================
# JOB MONITORING AGENT v3.0 — CONFIGURAÇÃO
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- TELEGRAM ---
# Obtenha com @BotFather no Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui
# Envie msg para o bot e acesse: api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# --- ANTHROPIC (para score semântico via Claude) ---
# Obtenha em console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Modelo: claude-haiku-4-5-20251001 (rápido/barato) ou claude-sonnet-4-6 (melhor)
SEMANTIC_MODEL=claude-haiku-4-5-20251001
# Habilita score via Claude API (true/false). Se false, usa keyword matching.
ENABLE_SEMANTIC_SCORING=true

# --- SCORING ---
MIN_SCORE_TO_NOTIFY=6.0    # Vagas acima disso geram notificação Telegram
MIN_SCORE_AUTO_CV=7.0      # Vagas acima disso geram CV automaticamente
SCORE_DISCARD_BELOW=2.0    # Vagas abaixo disso são descartadas

# --- SCHEDULER ---
CHECK_INTERVAL_HOURS=6     # Intervalo entre ciclos de busca (horas)

# --- DASHBOARD ---
FLASK_PORT=5000
FLASK_DEBUG=false          # true apenas para desenvolvimento local

# --- API FASTAPI (v3.0) ---
API_PORT=8000              # Porta da API FastAPI (separada do Flask na 5000)

# --- CARTAS DE APRESENTACAO (v3.0) ---
# Geradas automaticamente para vagas com score >= MIN_SCORE_AUTO_CV
ENABLE_COVER_LETTER=true

# --- LOGS ---
LOG_LEVEL=INFO             # DEBUG para mais detalhes

# --- MAILERLITE (email marketing autônomo) ---
# Gere em: https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=
# Email verificado em: https://dashboard.mailerlite.com/settings/domains
MAILERLITE_FROM_EMAIL=

# --- REDES SOCIAIS (opcionais — publicação automática) ---
# Twitter/X — Bearer Token (gere em developer.twitter.com)
TWITTER_BEARER_TOKEN=
# Dev.to — API Key (gere em dev.to/settings/extensions)
DEVTO_API_KEY=
# URL pública do dashboard (usada nos posts e emails)
DASHBOARD_URL=http://localhost:5173

# --- GITHUB (para push automático via GitAgent) ---
# Opção 1: Token pessoal (PAT) — recomendado para VPS
# Gere em: github.com/settings/tokens — escopo: repo (full)
# GITHUB_TOKEN=ghp_...
# Opção 2: SSH já configurado — nao precisa de token
# Verifique com: ssh -T git@github.com
# Configure com: bash scripts/setup_github.sh
